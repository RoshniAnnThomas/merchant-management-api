{
  "info": {
    "name": "Merchant Management API",
    "description": "Postman collection for Admin authentication, category creation, and merchant CRUD APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "jwtToken",
      "value": ""
    },
    {
      "key": "categoryId",
      "value": ""
    },
    {
      "key": "merchantId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Logs in the default admin and returns a JWT token."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.token) {",
                  "  pm.collectionVariables.set('jwtToken', response.token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwtToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "description": "JWT authorization example"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Grocery\",\n  \"description\": \"Daily grocery and supermarket merchants\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "categories"
              ]
            },
            "description": "Creates a category. Requires JWT bearer token."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.data && response.data._id) {",
                  "  pm.collectionVariables.set('categoryId', response.data._id);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Merchants",
      "item": [
        {
          "name": "Create Merchant",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwtToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "description": "JWT authorization example"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shopName\": \"Fresh Mart\",\n  \"phoneNumber\": \"+91 9876543210\",\n  \"ownerName\": \"Rahul Sharma\",\n  \"registrationNumber\": \"REG-1001\",\n  \"category\": \"{{categoryId}}\",\n  \"address\": \"12 Market Road, Mumbai\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/merchants",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "merchants"
              ]
            },
            "description": "Creates a merchant. The category field should contain a valid Category ObjectId."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.data && response.data._id) {",
                  "  pm.collectionVariables.set('merchantId', response.data._id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Merchants",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwtToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "description": "JWT authorization example"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/merchants",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "merchants"
              ]
            },
            "description": "Returns all merchants with populated category details."
          },
          "response": []
        },
        {
          "name": "Get Merchant By ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwtToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "description": "JWT authorization example"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/merchants/{{merchantId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "merchants",
                "{{merchantId}}"
              ]
            },
            "description": "Returns one merchant by ID with populated category details."
          },
          "response": []
        },
        {
          "name": "Edit Merchant",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwtToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "description": "JWT authorization example"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shopName\": \"Fresh Mart Supermarket\",\n  \"phoneNumber\": \"+91 9876543210\",\n  \"ownerName\": \"Rahul Sharma\",\n  \"registrationNumber\": \"REG-1001\",\n  \"category\": \"{{categoryId}}\",\n  \"address\": \"12 Market Road, Mumbai, Maharashtra\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/merchants/edit/{{merchantId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "merchants",
                "edit",
                "{{merchantId}}"
              ]
            },
            "description": "Updates a merchant by ID. Any merchant field may be sent."
          },
          "response": []
        },
        {
          "name": "Delete Merchant",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwtToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "description": "JWT authorization example"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/merchants/{{merchantId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "merchants",
                "{{merchantId}}"
              ]
            },
            "description": "Deletes a merchant by ID."
          },
          "response": []
        }
      ]
    }
  ]
}
